# Production Environment Variables for Render
# Copy these to your Render service environment settings

NODE_ENV=production
PORT=10000

# Database (Use Internal Database URL from Render PostgreSQL service)
DATABASE_URL=postgresql://user:password@host:port/pharmapay

# JWT Configuration (Generate a secure random string)
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secure-random-jwt-secret-key-change-this
JWT_EXPIRES_IN=7d

# CORS Configuration (Add your frontend URLs)
ALLOWED_ORIGINS=https://pharmapay-admin.onrender.com,https://pharmapay-store.onrender.com

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=info
